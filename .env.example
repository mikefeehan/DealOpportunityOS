OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
DATABASE_URL=sqlite:///./opportunityos.db
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Optional authorized private-source ingestion.
# Do not commit real credentials or cookies.
ACQUISITION_SOURCE_URLS=
YARDI_COOKIE=
REALPAGE_COOKIE=
HELLODATA_COOKIE=
YARDI_LOGIN_URL=
YARDI_USERNAME=
YARDI_PASSWORD=
REALPAGE_LOGIN_URL=
REALPAGE_USERNAME=
REALPAGE_PASSWORD=
HELLODATA_LOGIN_URL=
HELLODATA_USERNAME=
HELLODATA_PASSWORD=

# Mapbox (server-side geocoding). Frontend uses NEXT_PUBLIC_MAPBOX_TOKEN in frontend/.env.local.
MAPBOX_TOKEN=
